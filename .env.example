# ===========================================
# Boatswain Backend — Configuration Template
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer .env dans git
# ===========================================

PORT=4000

# --- Base de données ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# --- Authentification ---
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARS_RANDOM_HEX
JWT_EXPIRES_IN=8h

# --- Chiffrement ---
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=CHANGE_ME_MINIMUM_32_CHARS_RANDOM_HEX

# --- CORS ---
CORS_ORIGIN=http://localhost:5173

# --- WhatsApp Meta ---
WHATSAPP_API_VERSION=v22.0
# Générer avec: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
WHATSAPP_VERIFY_TOKEN=CHANGE_ME_RANDOM_HEX

# --- Environnement ---
NODE_ENV=development

# --- SMTP (emails) ---
SMTP_HOST=your.smtp.host
SMTP_PORT=465
SMTP_SECURE=true
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Boatswain

# --- APIs externes ---
TAVILY_API_KEY=tvly-CHANGE_ME
NEWSDATA_IO_API_KEY=pub_CHANGE_ME
GNEWS_API_KEY=CHANGE_ME
FIRECRAWL_API_KEY=fc-CHANGE_ME
WEBSCRAPING_AI_API_KEY=CHANGE_ME

# --- Nettoyage données démo ---
REMOVE_DEMO_DATA=false
