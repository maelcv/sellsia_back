{
  "id": "barchart_scrapper",
  "name": "Barchart.com Futures (Tous produits)",
  "type": "scrapping",
  "content_type": "price",
  "config": {
    "base_url": "https://www.barchart.com/futures/quotes/",
    "urls_to_scrape": [
      { "id": "colza",     "path": "RS*0/overview" },
      { "id": "soja",      "path": "ZS*0/overview" },
      { "id": "tournesol", "path": "ZL*0/overview" },
      { "id": "palme",     "path": "KO*0/overview" },
      { "id": "petrole",   "path": "CL*0/overview" }
    ],
    "urls_to_exclude": [],
    "navigation": {
      "wait_for_selector": "[data-ng-bind='quote.lastPrice'], .current-price",
      "wait_until": "domcontentloaded",
      "timeout": 12000,
      "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
    },
    "extraction_selectors": {
      "price": "[data-ng-bind='quote.lastPrice'], .current-price, .bc-price, [class*='price']",
      "variation": "[data-ng-bind='quote.change'], .price-change, .change",
      "variation_percent": "[data-ng-bind='quote.percentChange'], .percent-change, [class*='percent']"
    }
  }
}
