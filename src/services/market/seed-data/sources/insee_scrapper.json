      "wait_for_selector": "div.resultats-recherche",
      "timeout": 15000,
      "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
    },
    "extraction_selectors": {
      "items": "div.resultat-item",
      "item_title": "h3 a",
      "item_description": "p.desc",
      "item_url": "h3 a",
      "source_name": "INSEE France"
    }
  }
}
