{
  "name": "sellsia-dashboard-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "build": "npx prisma generate && npx prisma migrate reset --force --skip-generate && npx prisma db push --skip-generate --accept-data-loss && node src/seed.js",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "node src/seed.js",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma generate && npx prisma migrate reset --force --skip-generate && npx prisma db push --skip-generate --accept-data-loss",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "@mistralai/mistralai": "^1.15.1",
    "@prisma/client": "6.12.0",
    "@tavily/core": "^0.7.2",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "fastmcp": "^3.34.0",
    "handlebars": "^4.7.9",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.4",
    "otplib": "^13.4.0",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "puppeteer": "^23.11.1",
    "qrcode": "^1.5.4",
    "twilio": "^5.13.0",
    "yahoo-finance2": "^2.14.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "prisma": "6.12.0"
  }
}
